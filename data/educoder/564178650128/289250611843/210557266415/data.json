            "code": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n</head>\n<body>\n    <!-- ********* Begin ********* -->\n    <style>\n    body{\n       margin:30px;\n    }\n    table{\n       /*居中对齐*/\n        text-align:center;\n        \n\n    }\n    </style>\n    <!--设置表格-->\n<table border=\"2\" width=\"100%\" cellspacing=\"0\" cellpadding=\"6\">\n    <caption>本周财政计划</caption>\n        <tr>\n            <td rowspan=\"2\" colspan=\"2\">项目</td>\n            <td colspan=\"2\">本周发生</td>\n            <td rowspan=\"2\">备注</td>\n        </tr>\n        <tr>\n            <td>收入</td>\n            <td>支出</td>\n            <!-- <td></td> -->\n        </tr>\n        <tr>\n            <td rowspan=\"3\">收入</td>\n            <td>贷款收回</td>\n            <td>8700</td>\n            <td>0</td>\n            <td></td>\n        </tr>\n        <tr>\n            <td>内部转款</td>\n            <td>6000</td>\n            <td>0</td>\n            <td></td>\n        </tr>\n        <tr>\n            <td>收入合计</td>\n            <td>14700</td>\n            <td>0</td>\n            <td></td>\n        </tr>\n        <tr>\n            <td rowspan=\"3\">支出</td>\n            <td>采购支出</td>\n            <td>0</td>\n            <td>5000</td>\n            <td></td>\n        </tr>\n        <tr>\n            <td>工资支出</td>\n            <td>0</td>\n            <td>7000</td>\n            <td></td>\n        </tr>\n        <tr>\n            <td>支出合计</td>\n            <td>0</td>\n            <td>12000</td>\n            <td></td>\n        </tr>\n</table>\n        \n        \n    <!-- ********* End ********* -->\n</body>\n</html>",
            "filename": "test.html",
