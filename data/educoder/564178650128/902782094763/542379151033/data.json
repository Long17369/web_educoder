    "title": "表单元素——下拉列表",
    "content": [
        {
            "code": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n</head>\n<body>\n    选择版块：\n    <!-- ********* Begin ********* -->\n    <select>\n        <option>问答</option>\n        <option>分享</option>\n        <option>招聘</option>\n        <option selected=\"selected\">客户端测试</option>\n    </select>\n\t<!-- ********* End ********* -->\n</body>\n</html>",
            "filename": "test.html",
            "language": "html"
        }
