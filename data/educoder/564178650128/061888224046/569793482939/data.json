            "code": "<!DOCTYPE html>\n<html lang=\"zh\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  <title>元素选择器</title>\n  <style type=\"text/css\">\n    /* ********** BEGIN ********** */\n    /* 元素选择器 */\n    html {\n      background-color:#F0F0F0;\n    }\n\n    header {\n      padding:40px;\n      background-color: white;\n    }\n\n    footer {\n      margin-top: 20px;\n      font-size: 0.6em;\n      color: grey;\n    }\n\n    /* ********** END ********** */\n  </style>\n</head>\n<body>\n\n<div>\n\n  <header>\n    <li><a href=\"#chosen\">精选</a></li>\n    <li><a href=\"#news\">时事</a></li>\n    <li><a href=\"#finance\">财政</a></li>\n    <li><a href=\"#think\">思想</a></li>\n    <li><a href=\"#life\">生活</a></li>\n  </header>\n\n  <div>\n    <section>\n      <h2>精选</h2>\n      <li>精选新闻1</li>\n      <li>精选新闻2</li>\n      <li>精选新闻3</li>\n    </section>\n    <section>\n      <h2>时事</h2>\n      <li>时事新闻1</li>\n      <li>时事新闻2</li>\n      <li>时事新闻3</li>\n    </section>\n    <section>\n      <h2>财政</h2>\n      <li>财政新闻1</li>\n      <li>财政新闻2</li>\n      <li>财政新闻3</li>\n    </section>\n    <section>\n      <h2>思想</h2>\n      <li>思想新闻1</li>\n      <li>思想新闻2</li>\n      <li>思想新闻3</li>\n    </section>\n    <section>\n      <h2>生活</h2>\n      <li>生活新闻1</li>\n      <li>生活新闻2</li>\n      <li>生活新闻3</li>\n    </section>\n  </div>\n\n  <footer>Copyright (c) News Copyright Holder All Rights Reserved.</footer>\n\n</div>\n\n</body>\n</html>\n",
